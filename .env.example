# Copy to .env and fill in. NEVER commit the real .env.
# Tokens come from PartnerX. They expire every 90 days; the worker auto-renews
# and persists the new pair to TOKEN_STORE_PATH.
STREAMLINE_TOKEN_KEY=
STREAMLINE_TOKEN_SECRET=

# Where renewed tokens are persisted. Local: tokens.json. On Render: /var/data/tokens.json
TOKEN_STORE_PATH=tokens.json

# Protects admin endpoints (/audit, /token/renew) on the worker. Render generates this.
ADMIN_TOKEN=

# Optional: pin the exact Streamline "token expired" status code(s) once confirmed
# from the apidocs (comma-separated), e.g. E0007. Until then we match by description.
STREAMLINE_TOKEN_EXPIRED_CODES=
